pipeline {
    agent { label 'docker' }
    
    stages {
        stage('Check the docker cli') {
            steps {
            sh "docker --version"
            sh "docker ps -a"
            sh "docker-compose --version"
            }
        }

        stage('Docker-Build') {
            steps {
                echo "Docker Build Step here..."
                sh "docker build . -t pythonapp:v1"
            }
        }

        stage('DockerContainer Creation') {
            steps {
                echo "Running Docker Compose here..."
                sh "docker-compose up -d"
            }
        }

        stage('Cheking output') {
            steps {
                sh "docker ps"
		        sh "docker-compose ps"
            }
        }

        stage('app working') {
            steps {
               sh "curl localhost:9010"
            }
        }

        stage('Image Push') {
            steps {
                sh "aws ecr get-login-password --region us-east-1 | docker login --username AWS --password-stdin 941377121250.dkr.ecr.us-east-1.amazonaws.com"
                sh "docker tag pythonapp:v1 941377121250.dkr.ecr.us-east-1.amazonaws.com/pythonapp:v1"
                sh "docker push 941377121250.dkr.ecr.us-east-1.amazonaws.com/pythonapp:v1"
            }
        }

         stage('Check kube env') {
            steps {
                sh """
                minikube status
                kubectl get nodes
                """
            }
        }
        stage('deploy kube files') {
            steps {
                sh """
                kubectl apply -f py-redis-configmap
                kubectl rollout restart deployment py-deploy-cm
                kubectl rollout status deployment py-deploy-cm
                """
            }
        }
        stage('App testing on kube env') {
            steps {
               sh "curl 192.168.49.2:30115"
            }
        }
    }

}
